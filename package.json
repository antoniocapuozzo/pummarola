{
  "name": "pummarola",
  "description": "A rapid boilerplate for frontend web development with Pug, PostCSS, TypeScript and Vite",
  "version": "1.1.0",
  "license": "MIT",
  "main": "package.json",
  "bin": {
    "pummarola": "./source/cli/pummarola.ts"
  },
  "packageManager": "bun@1.3.5",
  "author": {
    "name": "Antonio Capuozzo",
    "url": "https://antoniocapuozzo.me"
  },
  "engines": {
    "bun": ">=1.3.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/antoniocapuozzo/pummarola.git"
  },
  "scripts": {
    "pummarola": "bun run ./source/cli/pummarola.ts",
    "dev": "bun run pummarola start",
    "start": "bun run pummarola start",
    "build": "bun run pummarola build",
    "preview": "bun run pummarola preview",
    "typecheck": "tsc --noEmit",
    "postinstall": "bun link",
    "__dev": "vite --open",
    "__build": "bun run typecheck && vite build",
    "__preview": "vite preview"
  },
  "dependencies": {
    "@clack/prompts": "^0.11.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.2",
    "@types/node": "^24.7.2",
    "@types/pug": "^2.0.10",
    "postcss": "^8.5.10",
    "postcss-preset-env": "^11.2.1",
    "pug": "^3.0.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.8"
  }
}
