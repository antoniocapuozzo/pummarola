//- Date mixin.
//- @author Pummarola
//- Usage: +date('1986-09-21')
//- Usage: +date('1986-09-21', 'it-IT')

mixin date(input, locale)
  - var isDateOnly = typeof input === 'string' && /^\d{4}-\d{2}-\d{2}$/.test(input)
  - var value = input instanceof Date ? input : new Date(isDateOnly ? input + 'T00:00:00' : input)
  - var isValidDate = !Number.isNaN(value.getTime())

  if isValidDate
    - var formatter = new Intl.DateTimeFormat(locale || 'en', { month: 'long', day: 'numeric', year: 'numeric' })
    - var datetime = isDateOnly ? input : value.toISOString()
    time(datetime=datetime)&attributes(attributes)= formatter.format(value)
