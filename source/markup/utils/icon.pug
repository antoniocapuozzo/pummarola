mixin icon(props = {})
  - var name = props.name || props
  - var title = props.title
  - var iconId = String(name || '')
  - iconId = iconId === 'project-logo' || iconId.indexOf('icon-') === 0 ? iconId : 'icon-' + iconId

  svg.site-icon&attributes(attributes)(
    aria-hidden=title ? null : 'true',
    role=title ? 'img' : null
  )
    if title
      title= title
    use(href='#' + iconId)
